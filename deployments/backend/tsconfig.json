{
  "compilerOptions": {
    "module": "commonjs",
    "jsx": "react-jsx",
    "lib": [
      "es2022",
      "DOM"
    ],
    "noImplicitReturns": false,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022"
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}
